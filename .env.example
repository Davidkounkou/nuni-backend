# Copiez ce fichier en ".env" et remplissez de vraies valeurs avant de lancer le serveur.
# Ne JAMAIS committer le vrai fichier .env dans Git.

# Clé secrète pour signer les sessions (tokens JWT). Générez une longue chaîne aléatoire.
JWT_SECRET=remplacez_moi_par_une_longue_chaine_aleatoire

# Clé que VOUS seul connaissez, utilisée pour activer un abonnement après paiement WhatsApp confirmé.
# Générez-en une forte, par exemple avec : node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=remplacez_moi_aussi

# Port d'écoute du serveur (Railway/Render le définissent automatiquement en général)
PORT=3000

# ---------- Email (envoi du code d'accès à l'admin) ----------
# Adresse Gmail qui envoie ET reçoit le code d'accès (ex : nunimisiki@gmail.com)
EMAIL_USER=nunimisiki@gmail.com

# Mot de passe d'application Gmail (PAS le mot de passe normal du compte).
# Pour l'obtenir :
#   1. Activez la validation en 2 étapes sur https://myaccount.google.com/security
#   2. Allez sur https://myaccount.google.com/apppasswords
#   3. Créez un mot de passe d'application (nom libre, ex "NUNI backend")
#   4. Collez le code à 16 caractères généré ici (sans espaces)
EMAIL_APP_PASSWORD=remplacez_moi_par_le_mot_de_passe_d_application_gmail
